---
import { BUSINESS } from '../consts';

interface Props {
  title?: string;
  lead?: string;
}

const {
  title = 'Not sure which system fits your space?',
  lead = 'Tell us about your building and we will help you choose the right system. We answer within one business day.',
} = Astro.props;
---

<section class="bg-brand-700">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl text-balance">{title}</h2>
      <p class="mt-5 text-lg leading-relaxed text-brand-100 text-pretty">{lead}</p>
      <div class="mt-9 flex flex-col justify-center gap-3 sm:flex-row">
        <a
          href="/contact"
          class="rounded-lg bg-accent-500 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-accent-600"
        >
          Request a consultation
        </a>
        <a
          href={`tel:${BUSINESS.phoneHref}`}
          class="rounded-lg bg-white/10 px-7 py-3.5 font-semibold text-white ring-1 ring-inset ring-white/25 transition-colors hover:bg-white/20"
        >
          Call {BUSINESS.phone}
        </a>
      </div>
    </div>
  </div>
</section>
