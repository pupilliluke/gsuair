---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { NAV, BUSINESS } from '../consts';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="shrink-0" aria-label={`${BUSINESS.name} — home`}>
      <Image src={logo} alt={BUSINESS.name} height={38} densities={[1, 2]} class="h-9 w-auto" loading="eager" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main">
      {
        NAV.map((item) =>
          item.children ? (
            <div class="group relative">
              <button
                type="button"
                class:list={[
                  'flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium transition-colors',
                  isActive(item.href) ? 'text-brand-600' : 'text-slate-700 hover:text-brand-600',
                ]}
                aria-expanded="false"
                aria-haspopup="true"
              >
                {item.label}
                <svg class="h-4 w-4 transition-transform group-hover:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path
                    fill-rule="evenodd"
                    d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </button>
              <div class="invisible absolute left-0 top-full w-64 pt-2 opacity-0 transition-all group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                <ul class="overflow-hidden rounded-xl border border-slate-200 bg-white py-1 shadow-lg">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={[
                          'block px-4 py-2.5 text-sm transition-colors hover:bg-brand-50 hover:text-brand-700',
                          path === child.href ? 'bg-brand-50 font-medium text-brand-700' : 'text-slate-700',
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                'rounded-md px-3 py-2 text-sm font-medium transition-colors',
                isActive(item.href) ? 'text-brand-600' : 'text-slate-700 hover:text-brand-600',
              ]}
            >
              {item.label}
            </a>
          )
        )
      }
      <a
        href={`tel:${BUSINESS.phoneHref}`}
        class="ml-2 rounded-lg bg-brand-500 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-brand-600"
      >
        {BUSINESS.phone}
      </a>
    </nav>

    <!-- Mobile toggle -->
    <button
      type="button"
      id="menu-toggle"
      class="rounded-md p-2 text-slate-700 lg:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-slate-200 bg-white lg:hidden">
    <nav class="mx-auto max-w-7xl px-4 py-3 sm:px-6" aria-label="Mobile">
      <ul class="space-y-1">
        {
          NAV.map((item) => (
            <li>
              {item.children ? (
                <>
                  <p class="px-3 pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-slate-400">{item.label}</p>
                  <ul>
                    {item.children.map((child) => (
                      <li>
                        <a href={child.href} class="block rounded-md px-3 py-2.5 text-slate-700 hover:bg-brand-50 hover:text-brand-700">
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a href={item.href} class="block rounded-md px-3 py-2.5 font-medium text-slate-700 hover:bg-brand-50 hover:text-brand-700">
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
      <a
        href={`tel:${BUSINESS.phoneHref}`}
        class="mt-4 block rounded-lg bg-brand-500 px-4 py-3 text-center font-semibold text-white"
      >
        Call {BUSINESS.phone}
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
</script>
