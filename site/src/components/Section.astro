---
interface Props {
  title?: string;
  eyebrow?: string;
  lead?: string;
  tone?: 'white' | 'tint' | 'brand';
  align?: 'left' | 'center';
  id?: string;
  class?: string;
}

const { title, eyebrow, lead, tone = 'white', align = 'left', id, class: className = '' } = Astro.props;

const tones = {
  white: 'bg-white',
  tint: 'bg-brand-50',
  brand: 'bg-brand-700 text-white',
};
---

<section id={id} class:list={[tones[tone], 'py-16 sm:py-20', className]}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    {
      (eyebrow || title || lead) && (
        <div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
          {eyebrow && (
            <p class:list={['text-sm font-semibold uppercase tracking-[0.2em]', tone === 'brand' ? 'text-accent-400' : 'text-brand-500']}>
              {eyebrow}
            </p>
          )}
          {title && (
            <h2 class:list={['mt-3 text-3xl font-bold tracking-tight sm:text-4xl text-balance', tone === 'brand' ? 'text-white' : 'text-brand-800']}>
              {title}
            </h2>
          )}
          {lead && (
            <p class:list={['mt-5 text-lg leading-relaxed text-pretty', tone === 'brand' ? 'text-brand-100' : 'text-slate-600']}>{lead}</p>
          )}
        </div>
      )
    }
    <slot />
  </div>
</section>
