---
import Base from '../layouts/Base.astro';
import { NAV } from '../consts';
---

<Base title="Page not found" noindex>
  <section class="mx-auto max-w-2xl px-4 py-28 text-center sm:px-6 sm:py-36">
    <p class="font-display text-sm font-bold uppercase tracking-[0.2em] text-accent-500">404</p>
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-brand-800 sm:text-5xl text-balance">
      We couldn't find that page
    </h1>
    <p class="mt-5 text-lg leading-relaxed text-slate-600">
      The page may have moved when we rebuilt this site. Try one of these instead:
    </p>
    <ul class="mt-9 flex flex-wrap justify-center gap-2.5">
      <li>
        <a href="/" class="inline-block rounded-lg border border-slate-300 px-5 py-2.5 font-medium text-slate-700 hover:border-brand-400 hover:text-brand-600">
          Home
        </a>
      </li>
      {
        NAV.map((item) => (
          <li>
            <a
              href={item.children ? item.children[0].href : item.href}
              class="inline-block rounded-lg border border-slate-300 px-5 py-2.5 font-medium text-slate-700 hover:border-brand-400 hover:text-brand-600"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
