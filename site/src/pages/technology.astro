---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import { BUSINESS } from '../consts';

import technologyHero from '../assets/technology-hero.jpg';

/*
 * 1:1 reproduction of the live gsuair.com Technology page: same headings, same
 * copy, same order, same download — nothing added, nothing removed. That
 * includes the "air travel" block at the bottom, kept at the owner's request.
 */
---

<Base
  title="Technology"
  description="The technology that provides the solution — how it works, and the Active Pure® Technology white paper."
>
  <PageHero
    size="lg"
    title="THE TECHNOLOGY THAT PROVIDES THE SOLUTION!"
    image={technologyHero}
    imageAlt="Researcher interacting with a molecular data visualization"
  >
    <p class="mt-6">
      <a
        href={`tel:${BUSINESS.phoneHref}`}
        class="text-lg font-semibold text-brand-100 underline underline-offset-4 transition-colors hover:text-white"
      >
        {BUSINESS.phone}
      </a>
    </p>
  </PageHero>

  <!-- Video -->
  <Section tone="tint">
    <VideoEmbed
      src="https://player.vimeo.com/video/1047595425?h=d2fc01db4e"
      title="HOW THE TECHNOLOGY WORKS!"
      caption="HOW THE TECHNOLOGY WORKS!"
    />
  </Section>

  <!-- The Path to Safer Indoor Air -->
  <Section tone="brand" align="center" title="The Path to Safer Indoor Air">
    <div class="mx-auto mt-10 max-w-3xl text-center">
      <p class="text-lg leading-relaxed text-brand-100">White Paper - Active Pure® Technology (pdf)</p>
      <a
        href="/pdfs/WhitePaper_PCOtechnology_Short.pdf"
        target="_blank"
        rel="noopener"
        class="mt-6 inline-block bg-white px-8 py-4 text-sm font-bold uppercase tracking-[0.15em] text-brand-800 shadow-md transition-colors hover:bg-brand-50"
      >
        Download
      </a>
    </div>
  </Section>

  <!-- Travel with GERM SOLUTIONS USA -->
  <Section tone="tint">
    <div class="mx-auto max-w-3xl">
      <h4 class="text-2xl font-bold tracking-tight text-brand-800 text-balance">
        Travel with GERM SOLUTIONS USA - Your Reliable Partner in Air Travel
      </h4>
      <p class="mt-6 text-lg leading-relaxed text-slate-700">
        At GERM SOLUTIONS USA, we are committed to making air travel simple, reliable and hassle-free. Our user-friendly
        platform and intuitive interface make it easy for you to book your flights, check-in online, and manage your
        bookings. We offer competitive prices, convenient schedules, and a wide range of destinations to choose from. Let
        us take care of your travel needs and enjoy a stress-free journey.
      </p>
    </div>
  </Section>
</Base>
