---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import CallToAction from '../components/CallToAction.astro';

import technologyHero from '../assets/technology-hero.jpg';

// NOTE: the old page carried a block of GoDaddy template filler about booking
// air travel — wrong business entirely. It is gone. The copy below is built from
// the company's own material and the ActivePure white paper linked at the bottom.
const steps = [
  {
    n: '01',
    title: 'Air and surface contaminants accumulate',
    copy: 'Every occupied room continuously generates airborne particles, viruses, bacteria, mold spores and VOCs. Sealed, energy-efficient buildings give them nowhere to dissipate.',
  },
  {
    n: '02',
    title: 'ActivePure® molecules are created',
    copy: 'Rather than waiting for air to pass through a filter, the ActivePure® cell converts ambient humidity and oxygen into powerful oxidizing molecules.',
  },
  {
    n: '03',
    title: 'The molecules leave the unit',
    copy: 'Those molecules are distributed into the room — through HVAC ductwork or from a portable unit — reaching surfaces and air a filter never touches.',
  },
  {
    n: '04',
    title: 'Pathogens are neutralized on impact',
    copy: 'The molecules seek out and neutralize contaminants at their point of origin: in the air and on desks, benches, handles and equipment. Protection is continuous, not periodic.',
  },
];

const differences = [
  {
    title: 'Beyond filtration',
    copy: 'A HEPA filter only treats the air that reaches it, and does nothing for surfaces. ActivePure® works throughout the room — on both.',
  },
  {
    title: 'Safe in occupied spaces',
    copy: 'Laboratory testing has cleared, and real-world application has demonstrated, that the technology can be used continuously in spaces occupied by people and pets.',
  },
  {
    title: 'No ozone',
    copy: 'UL2998 certified for zero ozone emissions, meeting California Air Resources Board limits — an important distinction from ionizers.',
  },
  {
    title: 'Proven in the field',
    copy: 'Used by thousands of schools, hospitals, offices and restaurants, and in hundreds of thousands of homes.',
  },
];
---

<Base
  title="Technology"
  description="How ActivePure® technology works: photocatalytic oxidation that neutralizes pathogens in the air and on surfaces continuously, safely, in occupied spaces."
>
  <PageHero
    eyebrow="ActivePure® Technology"
    title="The technology that provides the solution"
    lead="ActivePure® evolved from research originally developed for the space program. Instead of waiting for contaminants to reach a filter, it goes out and finds them — in the air and on every surface in the room."
    image={technologyHero}
    imageAlt="Researcher interacting with a molecular data visualization"
  />

  <Section align="center" eyebrow="Watch" title="How the technology works">
    <div class="mt-12">
      <VideoEmbed src="https://player.vimeo.com/video/1047595425?h=d2fc01db4e" title="How ActivePure® technology works" />
    </div>
  </Section>

  <Section tone="tint" eyebrow="The process" title="From ambient air to a protected room" align="center">
    <ol class="mt-12 grid gap-6 sm:grid-cols-2">
      {
        steps.map((s) => (
          <li class="rounded-2xl border border-brand-100 bg-white p-8">
            <span class="font-display text-sm font-bold tracking-widest text-accent-500">{s.n}</span>
            <h3 class="mt-3 text-xl font-semibold text-brand-800">{s.title}</h3>
            <p class="mt-3 leading-relaxed text-slate-600">{s.copy}</p>
          </li>
        ))
      }
    </ol>
  </Section>

  <Section eyebrow="Why it's different" title="Not a filter. Not an ionizer." align="center">
    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {
        differences.map((d) => (
          <div class="rounded-2xl border border-slate-200 p-8">
            <h3 class="text-lg font-semibold text-brand-700">{d.title}</h3>
            <p class="mt-2.5 leading-relaxed text-slate-600">{d.copy}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <Section tone="brand">
    <div class="grid items-center gap-10 lg:grid-cols-[2fr_1fr]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent-400">The path to safer indoor air</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl text-balance">
          Read the ActivePure® white paper
        </h2>
        <p class="mt-5 max-w-xl leading-relaxed text-brand-100">
          A technical overview of the photocatalytic oxidation (PCO) technology behind the system — how it is built, how
          it is tested, and what the results show.
        </p>
      </div>
      <a
        href="/pdfs/WhitePaper_PCOtechnology_Short.pdf"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-7 py-3.5 font-semibold text-brand-700 transition-colors hover:bg-brand-50 lg:justify-self-end"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0 4-4m-4 4-4-4M4 20h16"></path>
        </svg>
        Download white paper
      </a>
    </div>
  </Section>

  <CallToAction />
</Base>
