---
import { statSync } from 'node:fs';
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import CallToAction from '../components/CallToAction.astro';

import articlesHero from '../assets/articles-hero.jpg';

type Article = {
  year: string;
  title: string;
  blurb: string;
  file: string;
};

const articles: Article[] = [
  {
    year: '2024',
    title: 'Legislative news: indoor air quality',
    blurb: 'Where indoor air quality sits on the legislative agenda, and what it means for building operators.',
    file: 'legislative_converted_to_work_Article_IndoorAi.pdf',
  },
  {
    year: '2024',
    title: 'Dallas, TX residential health care facility reduces COVID-19 cases by 94%',
    blurb: 'A field study of ActivePure® deployed across a residential health care facility, and the reduction that followed.',
    file: 'Article_Study_ResidentialHealthCareFacility.pdf',
  },
  {
    year: '2024',
    title: 'Wildfires and your mind',
    blurb: 'Wildfire smoke does not stop at your lungs. What the research says about protecting your brain.',
    file: 'Article_ProtectYourBrainAgainstWildfires.pdf',
  },
  {
    year: '2023',
    title: 'Study gives great hope in combating MRSA',
    blurb: 'ActivePure® tested against methicillin-resistant Staphylococcus aureus.',
    file: 'Article_ActivePure_vsMRSA.pdf',
  },
  {
    year: '2023',
    title: 'ActivePure provides a solution for the medical industry',
    blurb: 'How the technology applies to clinical and care environments.',
    file: 'Article_ActivePure_Medical_s_Technology.pdf',
  },
  {
    year: '2022',
    title: 'Good ventilation helps against respiratory viruses',
    blurb: 'Why ventilation and purification work together, and where filtration alone falls short.',
    file: 'Article_About_Ventilation_and_Respiratory_Viru.pdf',
  },
  {
    year: 'Case study',
    title: 'Canine epidemic — Sumner County',
    blurb: 'Containing an airborne canine epidemic in a county facility.',
    file: 'CaseStudy_CanineEpidemic_SumnerCounty.pdf',
  },
  {
    year: 'White paper',
    title: 'ActivePure® technology (PCO)',
    blurb: 'The technical overview of the photocatalytic oxidation technology behind the system.',
    file: 'WhitePaper_PCOtechnology_Short.pdf',
  },
];

/** Read real file sizes at build time so the labels can never go stale. */
const sizeOf = (file: string) => {
  try {
    const bytes = statSync(`public/pdfs/${decodeURIComponent(file)}`).size;
    return bytes > 1048576 ? `${(bytes / 1048576).toFixed(1)} MB` : `${Math.round(bytes / 1024)} KB`;
  } catch {
    return null;
  }
};
---

<Base
  title="Articles"
  description="Research, field studies and legislative news on indoor air quality and ActivePure® technology — free PDF downloads."
>
  <PageHero
    eyebrow="Press"
    title="Articles worth reading"
    lead="Independent research, field studies and industry news on indoor air quality. All free to download."
    image={articlesHero}
    imageAlt="An open book with a green landscape growing out of its pages"
  />

  <Section>
    <ul class="grid gap-5 md:grid-cols-2">
      {
        articles.map((a) => {
          const size = sizeOf(a.file);
          return (
            <li>
              <a
                href={`/pdfs/${a.file}`}
                target="_blank"
                rel="noopener"
                class="group flex h-full gap-5 rounded-2xl border border-slate-200 p-7 transition-all hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-lg"
              >
                <span
                  class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-500 transition-colors group-hover:bg-brand-500 group-hover:text-white"
                  aria-hidden="true"
                >
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0 4-4m-4 4-4-4M4 20h16" />
                  </svg>
                </span>
                <span class="flex-1">
                  <span class="text-xs font-semibold uppercase tracking-wider text-accent-500">{a.year}</span>
                  <h2 class="mt-1.5 font-semibold leading-snug text-brand-800 text-balance">{a.title}</h2>
                  <span class="mt-2 block text-sm leading-relaxed text-slate-600">{a.blurb}</span>
                  <span class="mt-3 block text-xs font-medium text-slate-400">PDF{size && ` · ${size}`}</span>
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </Section>

  <CallToAction />
</Base>
