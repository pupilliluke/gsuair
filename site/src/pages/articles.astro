---
import { statSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';

import articlesHero from '../assets/articles-hero.jpg';

/*
 * 1:1 reproduction of the live gsuair.com/articles page: the same seven
 * downloads, in the same order, with the titles copied verbatim — typos and
 * spacing included ("MSRA", "2024 -Dallas", "Active Pure", "Covid -19").
 * The live page has no blurbs, no lead and no call to action; none are added.
 */

type Article = {
  /** Verbatim from the live page — do not correct the spelling or spacing. */
  title: string;
  file: string;
};

const articles: Article[] = [
  {
    title: '2024 - Legislative News',
    file: 'legislative_converted_to_work_Article_IndoorAi.pdf',
  },
  {
    title: '2022 - Good Ventilation Helps Respiratory Viruses',
    file: 'Article_About_Ventilation_and_Respiratory_Viru.pdf',
  },
  {
    title: '2024 - Wildfires and Your Mind',
    file: 'Article_ProtectYourBrainAgainstWildfires.pdf',
  },
  {
    title: '2024 -Dallas, TX Residential Health Care Facility Reduces Covid -19 Cases by 94%',
    file: 'Article_Study_ResidentialHealthCareFacility.pdf',
  },
  {
    title: '2023 - Active Pure Provides a Solution for the Medical Industry',
    file: 'Article_ActivePure_Medical_s_Technology.pdf',
  },
  {
    title: '2023 - Study Gives Great Hope in Combating MSRA',
    file: 'Article_ActivePure_vsMRSA.pdf',
  },
  {
    title: '2023 - Indoor Air System Helps a County Animal Control Facility Recover from a Viral Outbreak',
    file: 'CaseStudy_CanineEpidemic_SumnerCounty.pdf',
  },
];

/**
 * Read real file sizes at build time so the labels can never go stale.
 * Resolved relative to this module, not to cwd — a CI host may run the build
 * from the repo root rather than from site/, which would silently drop every size.
 */
const sizeOf = (file: string) => {
  try {
    const path = fileURLToPath(new URL(`../../public/pdfs/${decodeURIComponent(file)}`, import.meta.url));
    const bytes = statSync(path).size;
    return bytes > 1048576 ? `${(bytes / 1048576).toFixed(1)} MB` : `${Math.round(bytes / 1024)} KB`;
  } catch {
    return null;
  }
};
---

<Base
  title="Articles Worth Reading"
  description="Articles, studies and legislative news on indoor air quality and ActivePure® technology — free PDF downloads."
>
  <PageHero
    title="ARTICLES WORTH READING"
    image={articlesHero}
    imageAlt="An open book with a green landscape growing out of its pages"
  />

  <Section tone="tint">
    <ul class="mx-auto max-w-3xl divide-y divide-brand-200 border-y border-brand-200">
      {
        articles.map((a) => {
          const size = sizeOf(a.file);
          return (
            <li class="flex flex-col gap-3 py-6 sm:flex-row sm:items-center sm:justify-between sm:gap-8">
              <p class="text-lg leading-snug text-slate-700 text-pretty">
                {a.title} <span class="whitespace-nowrap text-slate-500">(pdf)</span>
                {size && <span class="ml-1 whitespace-nowrap text-sm text-slate-400">{size}</span>}
              </p>
              <a
                href={`/pdfs/${a.file}`}
                target="_blank"
                rel="noopener"
                class="shrink-0 self-start border border-slate-500 px-6 py-3 text-sm font-bold uppercase tracking-[0.15em] text-slate-800 transition-colors hover:border-brand-600 hover:text-brand-700 sm:self-auto"
              >
                Download
              </a>
            </li>
          );
        })
      }
    </ul>
  </Section>
</Base>
