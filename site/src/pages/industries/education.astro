---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import CallToAction from '../../components/CallToAction.astro';
import CheckList from '../../components/CheckList.astro';

import educationHero from '../../assets/education-hero.jpg';
import classroom from '../../assets/education-classroom.jpg';

const benefits = [
  'The #1 ranked continuous air purification system, capable of attacking COVID-19 in the air and on surfaces immediately',
  'Reduces almost 100% of surface and airborne contaminants within the first 24 hours of use',
  'Controls &amp; neutralizes contaminants such as viruses, bacteria, mold, fungi &amp; VOCs in real time',
  'Releases ActivePure® molecules that neutralize pathogens and contaminants on impact',
  'Minimal maintenance',
  'Ultra-quiet',
  'Cost-effective',
  'Installed and portable solutions available',
];
---

<Base
  title="Education"
  description="Improve student productivity and reduce absenteeism. ActivePure® air and surface purification for K-12 schools, colleges and entire districts. Grants and funding available."
>
  <PageHero
    eyebrow="Education"
    title="Improving student productivity and reducing absenteeism"
    lead="Germ Solutions USA believes school administrators, teachers, staff and children have the right to learn in a clean-air environment."
    image={educationHero}
    imageAlt="Brick school building on a sunny day"
  />

  <Section>
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr]">
      <div class="space-y-5 text-lg leading-relaxed text-slate-600">
        <p>
          Poor indoor air quality affects the health of each of us. For children, it can negatively affect their
          neurodevelopment and cognitive ability.
        </p>
        <p>
          Indoor air quality problems in schools have been linked to drowsiness, headaches, loss of concentration and
          asthma. It also increases absenteeism and leads to children falling behind academically. Class sizes
          predetermined by state boards of education make it more difficult to distance one child from another.
        </p>
        <p>
          Whether you need clean air in K-12 schools, elementary or primary schools, secondary schools, colleges,
          universities, trade schools or an entire school district, ActivePure® has a solution to meet your facilities'
          unique needs.
        </p>
      </div>
      <Image
        src={classroom}
        alt="Students raising their hands in a classroom"
        widths={[400, 700, 1000]}
        sizes="(min-width: 1024px) 26rem, 100vw"
        class="rounded-2xl shadow-lg"
        loading="lazy"
      />
    </div>
  </Section>

  <Section tone="tint" title="It doesn't just purify the air — it sanitizes surfaces" eyebrow="How it fits a school">
    <div class="mt-8 grid gap-12 lg:grid-cols-2">
      <div class="space-y-5 leading-relaxed text-slate-600">
        <p>
          HVAC-installed units as well as portables allow each school to customize a system to meet its specific needs.
          In older school buildings with poor ventilation, portable units get to work immediately — sanitizing exposed
          surfaces and the air in occupied spaces without the cost of overhauling an HVAC system.
        </p>
        <p>
          A school can simply place an ActivePure® unit in each classroom and plug it into a regular wall outlet. It is
          that easy.
        </p>
        <p>
          The system includes marketing materials to promote your investment and educate team members, educators,
          students and parents about the benefits for all.
        </p>
      </div>
      <div class="rounded-2xl border border-brand-100 bg-white p-8">
        <h3 class="text-lg font-semibold text-brand-800">System benefits</h3>
        <CheckList items={benefits} class="mt-6" />
      </div>
    </div>
  </Section>

  <Section align="center" eyebrow="Watch" title="Clean air in the classroom">
    <div class="mt-12">
      <VideoEmbed src="https://www.youtube.com/embed/6eXyTL8-2_A" title="ActivePure® in education" />
    </div>
  </Section>

  <Section tone="brand">
    <div class="grid items-center gap-10 lg:grid-cols-[2fr_1fr]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent-400">Grants &amp; funding</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl text-balance">
          Funding is available for educational facilities
        </h2>
        <p class="mt-5 max-w-xl leading-relaxed text-brand-100">
          Products may qualify under ESSER, EANS, COSTARS, PEPPM and TIPS. We are happy to help you work out which
          applies to your school.
        </p>
      </div>
      <a
        href="/funding"
        class="inline-flex items-center justify-center rounded-lg bg-white px-7 py-3.5 font-semibold text-brand-700 transition-colors hover:bg-brand-50 lg:justify-self-end"
      >
        See funding options
      </a>
    </div>
  </Section>

  <CallToAction
    title="Let's find the right system for your school"
    lead="Contact us any time — we will help you decide which air purification system is best for your facility."
  />
</Base>
