---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import CallToAction from '../../components/CallToAction.astro';
import CheckList from '../../components/CheckList.astro';

import growroomHero from '../../assets/growroom-hero.jpg';
import growroomModular from '../../assets/growroom-modular.jpg';

const results = [
  '24/7 continuous sanitization to prevent mold &amp; mildew',
  'Round-the-clock protection for your grow room, while also reducing bacteria and viruses that can harm staff and visitors',
  'Helps you pass microbial lab tests and reach true pharma-grade product',
];
---

<Base
  title="Grow Rooms"
  description="ActivePure® technology for cannabis cultivation: inactivate mold and fungi up to a 6-log reduction in high-density, high-humidity grow rooms."
>
  <PageHero
    eyebrow="Cultivation & Grow Rooms"
    title="Protecting crops from mold & mildew"
    lead="Growing in a sealed room with high humidity and numerous other variables creates a perfect storm for mold, mildew and contamination — and a cultivation crop disaster."
    image={growroomHero}
    imageAlt="Cannabis cultivation grow room under lights"
  />

  <Section>
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr]">
      <div class="space-y-5 text-lg leading-relaxed text-slate-600">
        <h2 class="text-3xl font-bold tracking-tight text-brand-800 sm:text-4xl">Grow rooms</h2>
        <p>
          ActivePure® technology is designed specifically for high-density, high-humidity areas such as cannabis
          cultivation environments. Our proprietary technology is in the Space Foundation Hall of Fame.
        </p>
        <p>
          This world-renowned technology turns humidity in the air into a DHP solution that inactivates mold and fungi
          up to a <strong class="font-semibold text-brand-700">6-log reduction</strong>. The result is a clean-room
          environment that allows your plants to thrive and helps you pass microbial lab tests — creating true
          pharma-grade product. ActivePure® inactivates pathogens where they grow.
        </p>
        <p>
          We understand that grow rooms require a solution that reduces the environmental load. The technology sanitizes
          both air and surfaces within the environment quickly and effectively. Molecules are distributed through
          HVAC/InDuct systems or portable units, attacking pathogens at their point of origin — on the plants, benches,
          light ballasts and pots, in the air and on surfaces.
        </p>
      </div>
      <Image
        src={growroomModular}
        alt="Cutaway view of a modular grow room with tiered planting racks"
        widths={[400, 700, 1000]}
        sizes="(min-width: 1024px) 26rem, 100vw"
        class="rounded-2xl bg-brand-50 p-4"
        loading="lazy"
      />
    </div>
  </Section>

  <Section tone="tint">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-brand-800 sm:text-4xl">The results</h2>
        <CheckList items={results} class="mt-7" />
      </div>
      <figure class="rounded-2xl border-l-4 border-accent-500 bg-white p-8 shadow-sm">
        <blockquote class="text-lg leading-relaxed text-slate-700">
          <p>
            "I have tried many systems that claim they can reduce these problematic issues within my grow rooms, but
            there has only been one that actually did — and that's ActivePure® technology."
          </p>
        </blockquote>
        <figcaption class="mt-6 text-sm font-semibold text-brand-700">
          Karl O. <span class="font-normal text-slate-500">— Owner, Tulsa, OK</span>
        </figcaption>
      </figure>
    </div>
  </Section>

  <CallToAction
    title="Protect your next harvest"
    lead="Tell us the size and setup of your grow space and we will recommend an InDuct or portable configuration."
  />
</Base>
