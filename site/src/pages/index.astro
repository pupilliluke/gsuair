---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import CheckList from '../components/CheckList.astro';
import { BUSINESS } from '../consts';

import homeHero from '../assets/home-hero.jpg';
import breatheEasy from '../assets/breathe-easy.jpg';
import unitSeal from '../assets/unit-guardian-seal.png';
import aerusBenefits from '../assets/aerus-benefits.jpg';

/*
 * 1:1 reproduction of the live gsuair.com homepage: same sections, same order,
 * same copy, same image placement — nothing added, nothing removed. That
 * includes the two editor notes in the intro, kept at the owner's request.
 */

// Verbatim from the live homepage.
const aerusBenefitsList = [
  'Reduce airborne &amp; surface contaminants',
  'Reduce pathogens in the air &amp; on surfaces in real time',
  'Greater than 99.9% effective against enveloped viruses, bacteria, fungi, non-enveloped viruses, mycobacteria, and spores',
  '24/7 continuous sanitization protection to prevent mold &amp; mildew',
  'Continuously cleans and protects air surfaces 24 hours a day',
  'Neutralizes over 99.9% of airborne SARS-COV-2 within 1 minute',
  'The only air-cleaning technology awarded the Certified Space Technology Seal by the Space Foundation',
];
---

<Base>
  <PageHero
    size="lg"
    title="The Best Indoor Air Purification System Available!"
    lead={`Call Us Now ${BUSINESS.phone}`}
    image={homeHero}
    imageAlt="Sunlight through a canopy of green trees against a blue sky"
  />

  <!-- Intro -->
  <Section tone="tint">
    <div class="mx-auto max-w-3xl space-y-6 text-lg leading-relaxed text-slate-700">
      <p>
        THIS INTRO IS NOT FINISHED BUT IT IS NEEDED. EVERY WEBSITE NEEDS TO START BY SAYING WHO YOU ARE AND WHAT YOU
        DO..
      </p>
      <p>
        GERM SOLUTIONS, USA is dedicated to the quality of the indoor air we breathe every day...work, home, hotels,
        restaurants, schools, entertainment facilities, manufacturing plants, etc... the quality of indoor air has been
        proven to benefit our health.
      </p>
      <p>Perhaps move EPA info here because it states the problems.</p>
      <p>
        Browse our site to learn more about our Air Purification System, and contact us anytime. We are happy to help you
        choose the correct system for your specific need.
      </p>
    </div>
  </Section>

  <!-- Video + Covid-19 value prop -->
  <Section tone="brand">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <figure class="aspect-video overflow-hidden rounded-2xl bg-brand-900 shadow-xl">
        <iframe
          src="https://player.vimeo.com/video/1047595425?h=d2fc01db4e"
          title="ActivePure Technology How It Works Video"
          class="h-full w-full"
          loading="lazy"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"
          allowfullscreen></iframe>
      </figure>
      <p class="text-lg leading-relaxed text-brand-100">
        GERM SOLUTIONS believe clean indoor air should not be considered a luxury, but because of Covid-19, the air we
        breathe and the things we touch can be a cause for health concerns. Proven by science, our technology neutralizes
        the pathogens in the air we breathe and the surfaces we touch. The products give peace of mind by implementing a
        constant layer of protection.
      </p>
    </div>
  </Section>

  <!-- Indoor Clean Air Is Making A Difference In Our Lives -->
  <Section tone="tint">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-brand-800 sm:text-4xl text-balance">
          Indoor Clean Air Is Making A Difference In Our Lives
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-slate-700">
          The Environmental Protection Agency estimates indoor air can be up to 100 times more polluted than outdoor air.
          There's no telling what microscopic particles are circulating through your HVAC system. Improving indoor air
          quality for you and your loved ones will result in significant health benefits. Outfit your home, school,
          office building or retail space with the most effective air purification system on the market. Call us! We can
          answer any questions.
        </p>
      </div>
      <Image
        src={breatheEasy}
        alt="A woman standing outdoors with her arms open, breathing deeply"
        widths={[400, 600, 900]}
        sizes="(min-width: 1024px) 28rem, 80vw"
        class="mx-auto aspect-square w-full max-w-md rounded-full object-cover shadow-lg"
        loading="lazy"
      />
    </div>
  </Section>

  <!-- The Solution For Every Indoor Setting -->
  <Section tone="brand">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl text-balance">
          The Solution For Every Indoor Setting
        </h2>
        <div class="mt-6 space-y-5 text-lg leading-relaxed text-brand-100">
          <p>
            ActivePure® technology evolved from the space program and is now used by thousands of schools, hospitals,
            offices, restaurants, and other businesses and in hundreds of thousands of homes.
          </p>
          <p>
            Laboratory testing has cleared — and real-world application has demonstrated — that ActivePure® is a
            technology that can be used continuously and in occupied spaces.
          </p>
          <p>
            The technology is scientifically proven to reduce airborne contaminants. Lab tests have demonstrated that the
            use of ActivePure® results in a 99.98% reduction in SARS-CoV-2 particles in the air and on surfaces.
            (SARS-CoV-2 is the virus that causes COVID-19.) A system can be deployed in both installed and portable
            solutions.
          </p>
        </div>
      </div>
      <figure class="mx-auto w-full max-w-md overflow-hidden rounded-2xl shadow-xl">
        <Image
          src={unitSeal}
          alt="Beyond Guardian Air purification unit with the ActivePure certification seal"
          widths={[400, 700, 1000]}
          sizes="(min-width: 1024px) 28rem, 80vw"
          class="w-full bg-white object-contain"
          loading="lazy"
        />
        <figcaption
          class="bg-brand-600 py-3 text-center font-display text-lg font-bold tracking-wider text-white"
        >
          BEYOND GUARDIAN AIR
        </figcaption>
      </figure>
    </div>
  </Section>

  <!-- Benefits Of Aerus Products -->
  <Section tone="tint">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <Image
        src={aerusBenefits}
        alt="Autumn trees against a blue sky"
        widths={[400, 600, 900]}
        sizes="(min-width: 1024px) 28rem, 80vw"
        class="mx-auto aspect-square w-full max-w-md rounded-full object-cover shadow-lg"
        loading="lazy"
      />
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-brand-800 sm:text-4xl text-balance">
          Benefits Of Aerus® Products
        </h2>
        <CheckList items={aerusBenefitsList} class="mt-8" />
      </div>
    </div>
  </Section>

  <!-- Funding programs -->
  <Section tone="brand">
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-display text-2xl font-bold leading-relaxed tracking-wide text-white sm:text-3xl text-balance">
        ESSER - EANS 11 - GEER - UGG - FEMA - CAPE - TIPS - PEPPM - OTHER FEDERAL AND STATE PROGRAMS
      </p>
      <a
        href="/funding"
        class="mt-10 inline-block bg-white px-8 py-4 text-sm font-bold uppercase tracking-[0.15em] text-brand-800 shadow-md transition-colors hover:bg-brand-50"
      >
        Click here for funding information
      </a>
    </div>
  </Section>

  <!-- Accreditations | Our Customers Are Our Priority -->
  <Section tone="tint">
    <div class="grid gap-12 md:grid-cols-2 md:gap-0">
      <div class="flex flex-col items-center px-4 text-center md:border-r md:border-brand-200 md:px-10">
        <h2 class="text-3xl font-bold tracking-tight text-brand-800">Accreditations</h2>
        <p class="mt-6 flex-1 text-lg leading-relaxed text-slate-700">
          GERM SOLUTIONS USA is deeply committed to all aspects related to the quality of indoor air. We follow industry
          guidelines and the specific standards necessary to remain compliant. View our credentials.
        </p>
        <a
          href="/accreditations"
          class="mt-9 inline-block border border-slate-500 px-8 py-4 text-sm font-bold uppercase tracking-[0.15em] text-slate-800 transition-colors hover:border-brand-600 hover:text-brand-700"
        >
          Accreditations
        </a>
      </div>

      <div class="flex flex-col items-center px-4 text-center md:px-10">
        <h2 class="text-3xl font-bold tracking-tight text-brand-800">Our Customers Are Our Priority!</h2>
        <p class="mt-6 flex-1 text-lg leading-relaxed text-slate-700">
          <a href="/contact" class="font-bold text-brand-700 underline underline-offset-2 hover:text-brand-600">
            Reach out
          </a>
          to us anytime. We are here to help you determine which air purification system is the best solution for your
          needs.
        </p>
        <a
          href="/contact"
          class="mt-9 inline-block border border-slate-500 px-8 py-4 text-sm font-bold uppercase tracking-[0.15em] text-slate-800 transition-colors hover:border-brand-600 hover:text-brand-700"
        >
          Contact us
        </a>
      </div>
    </div>
  </Section>
</Base>
