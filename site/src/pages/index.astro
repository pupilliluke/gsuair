---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import CallToAction from '../components/CallToAction.astro';
import CheckList from '../components/CheckList.astro';
import { BUSINESS } from '../consts';

import homeHero from '../assets/home-hero.jpg';
import unitSeal from '../assets/unit-guardian-seal.png';
import breatheEasy from '../assets/breathe-easy.jpg';

// Recovered from SCHOOL BULLETED INFO FINAL.png, where this list was trapped as
// pixels. As real text it is searchable, screen-readable and responsive.
const systemBenefits = [
  'The #1 ranked continuous air purification system, capable of attacking COVID-19 in the air and on surfaces immediately',
  'Reduces almost 100% of surface and airborne contaminants within the first 24 hours of use',
  'Controls &amp; neutralizes contaminants such as viruses, bacteria, mold, fungi &amp; VOCs in real time',
  'Releases ActivePure® molecules that neutralize pathogens and contaminants on impact',
  'Minimal maintenance',
  'Ultra-quiet',
  'Cost-effective',
  'Installed and portable solutions available',
];

const sectors = [
  { title: 'Education', href: '/industries/education', copy: 'Fewer absences, better focus. Portable or HVAC-installed, classroom by classroom.' },
  { title: 'Government Facilities', href: '/industries/government-facilities', copy: 'Meet OSHA and EPA obligations in high-traffic public buildings.' },
  { title: 'Grow Rooms', href: '/industries/manufacturing', copy: 'Mold and mildew control for high-humidity cannabis cultivation.' },
  { title: 'Retail: Cigar & Tobacco', href: '/industries/retail', copy: 'Protect humidors and seed beds from mold and fungi.' },
  { title: 'Residences & Home Offices', href: '/industries/residences', copy: 'Dust, dander, allergens and odors — handled 24/7.' },
];
---

<Base>
  <PageHero
    size="lg"
    eyebrow="ActivePure® Technology"
    title="The best indoor air purification system available"
    lead="Germ Solutions USA is dedicated to the quality of the air we breathe every day — at work, at home, in schools, restaurants, hotels and manufacturing plants. Proven by science, our technology neutralizes pathogens in the air we breathe and on the surfaces we touch."
    image={homeHero}
    imageAlt="Sunlight through a canopy of green trees against a blue sky"
  >
    <div class="mt-9 flex flex-col gap-3 sm:flex-row">
      <a
        href="/contact"
        class="rounded-lg bg-accent-500 px-7 py-3.5 text-center font-semibold text-white transition-colors hover:bg-accent-600"
      >
        Request a consultation
      </a>
      <a
        href={`tel:${BUSINESS.phoneHref}`}
        class="rounded-lg bg-white/10 px-7 py-3.5 text-center font-semibold text-white ring-1 ring-inset ring-white/25 transition-colors hover:bg-white/20"
      >
        Call {BUSINESS.phone}
      </a>
    </div>
  </PageHero>

  <!-- EPA statistic: the old site's editor note asked for this to lead, since it frames the problem. -->
  <Section tone="tint">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-500">The problem</p>
        <p class="mt-5 text-5xl font-bold tracking-tight text-brand-700 sm:text-6xl">
          100<span class="text-3xl sm:text-4xl">×</span>
        </p>
        <p class="mt-3 text-xl font-semibold text-brand-800">
          The EPA estimates indoor air can be up to 100 times more polluted than outdoor air.
        </p>
        <p class="mt-5 leading-relaxed text-slate-600">
          There's no telling what microscopic particles are circulating through your HVAC system. Improving indoor air
          quality for you and your loved ones results in significant health benefits — outfit your home, school, office
          building or retail space with the most effective air purification system on the market.
        </p>
        <p class="mt-5 leading-relaxed text-slate-600">
          Clean indoor air should not be a luxury. Our products give peace of mind by adding a constant layer of
          protection.
        </p>
      </div>
      <Image
        src={breatheEasy}
        alt="A woman standing outdoors with her arms open, breathing deeply"
        widths={[480, 800, 1200]}
        sizes="(min-width: 1024px) 42rem, 100vw"
        class="rounded-2xl shadow-lg"
        loading="lazy"
      />
    </div>
  </Section>

  <Section
    title="How the technology works"
    eyebrow="Watch"
    align="center"
    lead="ActivePure® evolved from the space program and is now used by thousands of schools, hospitals, offices and restaurants — and in hundreds of thousands of homes."
  >
    <div class="mt-12">
      <VideoEmbed
        src="https://player.vimeo.com/video/1047595425?h=d2fc01db4e"
        title="How ActivePure® technology works"
      />
    </div>
  </Section>

  <Section tone="tint">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <Image
        src={unitSeal}
        alt="Beyond Guardian Air purification unit with its certification seal"
        widths={[400, 700, 1000]}
        sizes="(min-width: 1024px) 36rem, 100vw"
        class="mx-auto rounded-2xl"
        loading="lazy"
      />
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-500">The solution</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-brand-800 sm:text-4xl text-balance">
          Safe for continuous use in occupied spaces
        </h2>
        <p class="mt-5 leading-relaxed text-slate-600">
          Laboratory testing has cleared — and real-world application has demonstrated — that ActivePure® can be used
          continuously in occupied spaces, and is scientifically proven to reduce airborne contaminants.
        </p>
        <CheckList items={systemBenefits} class="mt-8" />
      </div>
    </div>
  </Section>

  <Section
    title="The solution for every indoor setting"
    eyebrow="Industries"
    align="center"
    lead="From a single classroom to an entire correctional facility, the system scales to the space."
  >
    <ul class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        sectors.map((s) => (
          <li>
            <a
              href={s.href}
              class="group flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-7 transition-all hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-lg"
            >
              <h3 class="text-lg font-semibold text-brand-700">{s.title}</h3>
              <p class="mt-2.5 flex-1 text-sm leading-relaxed text-slate-600">{s.copy}</p>
              <span class="mt-5 text-sm font-semibold text-brand-500 transition-transform group-hover:translate-x-0.5">
                Learn more <span aria-hidden="true">→</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </Section>

  <CallToAction
    title="Browse our site, then talk to a person"
    lead="We are happy to help you choose the correct system for your specific need — no pressure, no jargon."
  />
</Base>
