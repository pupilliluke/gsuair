---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import { BUSINESS, FORMSPREE_ENDPOINT } from '../consts';

import contactHero from '../assets/contact-hero.jpg';

/*
 * 1:1 reproduction of the live gsuair.com Contact Us page: same headings, same
 * copy, same order — nothing added, nothing removed.
 *
 * Two deliberate corrections, both confirmed by the owner: the phone is
 * 724.900.3853 (the live contact page still shows the old 8353) and the street
 * is 204 N. Main (the live contact page says 104). Both come from BUSINESS so
 * the two can never drift apart again.
 *
 * The live page's "This site is protected by reCAPTCHA" notice is not
 * reproduced: this form posts to Formspree and has no reCAPTCHA on it, so the
 * notice would be a false claim about the visitor's data rather than copy.
 */

const mapQuery = encodeURIComponent(
  `${BUSINESS.street}, ${BUSINESS.city}, ${BUSINESS.stateLong} ${BUSINESS.zip}`
);
const directionsHref = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;
---

<Base
  title="Contact Us"
  description={`Let us know what you need. We will call you within 24 hours, and look forward to meeting you. ${BUSINESS.street}, ${BUSINESS.city}, ${BUSINESS.state} ${BUSINESS.zip}. ${BUSINESS.phone}.`}
>
  <PageHero title={`CONTACT US ${BUSINESS.phone}`} image={contactHero} imageAlt="Hands holding a mobile phone" />

  <Section tone="tint" title="Contact Us">
    <div class="mt-12 grid gap-14 lg:grid-cols-[1.2fr_1fr]">
      <div>
        <h4 class="text-xl font-bold leading-relaxed tracking-tight text-brand-800 text-balance">
          Let Us Know What You Need. We will call you within 24 hours, and look forward to meeting you.
        </h4>

        <form action={FORMSPREE_ENDPOINT} method="POST" class="mt-8 space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700">Name*</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="mt-1.5 block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-900 focus:border-brand-500 focus:ring-brand-500"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-slate-700">Email*</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="mt-1.5 block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-900 focus:border-brand-500 focus:ring-brand-500"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-slate-700">Phone Number *</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              autocomplete="tel"
              class="mt-1.5 block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-900 focus:border-brand-500 focus:ring-brand-500"
            />
          </div>

          <!-- Honeypot: bots fill hidden fields, humans never see this. -->
          <div class="hidden" aria-hidden="true">
            <label for="_gotcha">Leave this field empty</label>
            <input type="text" id="_gotcha" name="_gotcha" tabindex="-1" autocomplete="off" />
          </div>

          <input type="hidden" name="_subject" value="New enquiry from gsuair.com" />

          <button
            type="submit"
            class="w-full rounded-lg bg-accent-500 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-accent-600 sm:w-auto"
          >
            Submit
          </button>
        </form>
      </div>

      <aside>
        <h4 class="text-xl font-bold leading-relaxed tracking-tight text-brand-800 text-balance">
          Submit the form, or call us at
          <a href={`tel:${BUSINESS.phoneHref}`} class="text-brand-600 hover:text-brand-700">{BUSINESS.phone}</a>
        </h4>

        <div class="mt-8 rounded-2xl bg-white p-8 shadow-sm">
          <h4 class="font-display text-lg font-bold uppercase tracking-wider text-brand-800">{BUSINESS.name}</h4>
          <p class="mt-3 leading-relaxed text-slate-700">
            {BUSINESS.street}, {BUSINESS.city}, {BUSINESS.stateLong} {BUSINESS.zip}, {BUSINESS.country}
          </p>
          <p class="mt-3">
            <a href={`tel:${BUSINESS.phoneHref}`} class="text-lg font-semibold text-brand-600 hover:text-brand-700">
              {BUSINESS.phone}
            </a>
          </p>

          <h4 class="mt-8 font-display text-lg font-bold uppercase tracking-wider text-brand-800">Hours</h4>
          <p class="mt-3 text-slate-700">
            <span class="font-semibold">Open today</span><br />
            {BUSINESS.hours}
          </p>

          <a
            href={directionsHref}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-block border border-slate-500 px-8 py-4 text-sm font-bold uppercase tracking-[0.15em] text-slate-800 transition-colors hover:border-brand-600 hover:text-brand-700"
          >
            Get directions
          </a>
        </div>
      </aside>
    </div>
  </Section>
</Base>
