---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import { BUSINESS, FORMSPREE_ENDPOINT } from '../consts';

import contactHero from '../assets/contact-hero.jpg';

const mapQuery = encodeURIComponent(`${BUSINESS.street}, ${BUSINESS.city}, ${BUSINESS.state} ${BUSINESS.zip}`);
---

<Base
  title="Contact Us"
  description={`Tell us what you need and we will call you within one business day. ${BUSINESS.street}, ${BUSINESS.city}, ${BUSINESS.state} ${BUSINESS.zip}. ${BUSINESS.phone}.`}
>
  <PageHero
    eyebrow="Contact"
    title="Let us know what you need"
    lead="We will call you within 24 hours, and look forward to meeting you."
    image={contactHero}
    imageAlt="Hands holding phones"
  />

  <Section>
    <div class="grid gap-14 lg:grid-cols-[1.2fr_1fr]">
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-brand-800">Send us a message</h2>
        <p class="mt-2 text-slate-600">Fields marked with an asterisk are required.</p>

        <form action={FORMSPREE_ENDPOINT} method="POST" class="mt-8 space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700">Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="mt-1.5 block w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:ring-brand-500"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-slate-700">Email *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="mt-1.5 block w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:ring-brand-500"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-slate-700">Phone number *</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              autocomplete="tel"
              class="mt-1.5 block w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:ring-brand-500"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-slate-700">
              How can we help? <span class="font-normal text-slate-400">(optional)</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Tell us about your space — a classroom, a grow room, a lounge, your home…"
              class="mt-1.5 block w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:ring-brand-500"
            ></textarea>
          </div>

          <!-- Honeypot: bots fill hidden fields, humans never see this. -->
          <div class="hidden" aria-hidden="true">
            <label for="_gotcha">Leave this field empty</label>
            <input type="text" id="_gotcha" name="_gotcha" tabindex="-1" autocomplete="off" />
          </div>

          <input type="hidden" name="_subject" value="New enquiry from gsuair.com" />

          <button
            type="submit"
            class="w-full rounded-lg bg-accent-500 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-accent-600 sm:w-auto"
          >
            Send message
          </button>
        </form>
      </div>

      <aside class="rounded-2xl bg-brand-50 p-8">
        <h2 class="text-2xl font-bold tracking-tight text-brand-800">{BUSINESS.name}</h2>
        <dl class="mt-8 space-y-7">
          <div>
            <dt class="text-sm font-semibold uppercase tracking-wider text-slate-500">Address</dt>
            <dd class="mt-2">
              <a
                href={`https://www.google.com/maps/search/?api=1&query=${mapQuery}`}
                target="_blank"
                rel="noopener noreferrer"
                class="leading-relaxed text-slate-700 hover:text-brand-600"
              >
                {BUSINESS.street}<br />
                {BUSINESS.city}, {BUSINESS.stateLong} {BUSINESS.zip}<br />
                {BUSINESS.country}
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-semibold uppercase tracking-wider text-slate-500">Phone</dt>
            <dd class="mt-2">
              <a href={`tel:${BUSINESS.phoneHref}`} class="text-lg font-semibold text-brand-600 hover:text-brand-700">
                {BUSINESS.phone}
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-semibold uppercase tracking-wider text-slate-500">Email</dt>
            <dd class="mt-2">
              <a href={`mailto:${BUSINESS.email}`} class="break-all text-slate-700 hover:text-brand-600">
                {BUSINESS.email}
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-semibold uppercase tracking-wider text-slate-500">Hours</dt>
            <dd class="mt-2 text-slate-700">{BUSINESS.hoursShort}</dd>
          </div>
        </dl>
      </aside>
    </div>
  </Section>
</Base>
