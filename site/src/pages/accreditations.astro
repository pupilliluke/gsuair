---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import { BUSINESS } from '../consts';

/*
 * 1:1 reproduction of the live gsuair.com/accreditations page: the same four
 * credential blocks, in the same order, with the copy and link targets carried
 * over verbatim — nothing added, nothing removed.
 *
 * The live COSTARS™ block is a heading and a VIEW link with no body copy; it
 * stays that way here. Its PDF is still hosted on germsolutionsusa.com, so the
 * link points off-site rather than at /pdfs.
 */

// Verbatim from the live page. Order matches the live page top to bottom.
const accreditations = [
  {
    name: 'IFMA - FACILITY MANAGEMENT PROFESSIONALS ASSOCIATION',
    body: "Founded in 1980, we are the world's largest and most widely recognized association for facility management professionals, supporting over 24,000 members in more than 100 countries.",
    linkLabel: 'Learn More',
    href: 'https://www.ifma.org/about/about-ifma/',
  },
  {
    name: 'ASHRAE',
    body: 'ASHRAE is an international society of heating, refrigerating, and air-conditioning professionals. Founded in 1894, ASHRAE is dedicated to advancing human well-being through sustainable technology for the built environment.',
    linkLabel: 'Learn More',
    href: 'https://www.ashrae.org/',
  },
  {
    name: 'COSTARS™ MEMBERSHIP LETTER',
    body: null,
    linkLabel: 'VIEW',
    href: 'https://germsolutionsusa.com/files/2024/01/Costars_2023-2024_Letter_008-E22-918.pdf',
  },
  {
    name: 'BBB',
    body: 'The Better Business Bureau (BBB) is a private, non-profit organization that gathers information about businesses and provides consumers with access to this data to help them make informed decisions.',
    linkLabel: 'Find out more',
    href: 'https://www.bbb.org/',
  },
];
---

<Base
  title="Accreditations"
  description="Germ Solutions USA follows industry guidelines and the specific standards necessary to remain compliant. View our credentials: IFMA, ASHRAE, COSTARS and the BBB."
>
  <PageHero title="ACCREDITATIONS" lead={BUSINESS.phone} />

  {
    accreditations.map((item, i) => {
      const onBrand = i % 2 === 1;
      return (
        <Section tone={onBrand ? 'brand' : 'tint'}>
          <div class="mx-auto max-w-3xl text-center">
            <h2
              class:list={[
                'font-display text-2xl font-bold tracking-wide text-balance sm:text-3xl',
                onBrand ? 'text-white' : 'text-brand-800',
              ]}
            >
              {item.name}
            </h2>
            {item.body && (
              <p
                class:list={[
                  'mt-6 text-lg leading-relaxed text-pretty',
                  onBrand ? 'text-brand-100' : 'text-slate-700',
                ]}
              >
                {item.body}
              </p>
            )}
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                'mt-9 inline-block border px-8 py-4 text-sm font-bold uppercase tracking-[0.15em] transition-colors',
                onBrand
                  ? 'border-white/70 text-white hover:border-white hover:bg-white hover:text-brand-800'
                  : 'border-slate-500 text-slate-800 hover:border-brand-600 hover:text-brand-700',
              ]}
            >
              {item.linkLabel}
            </a>
          </div>
        </Section>
      );
    })
  }
</Base>
