---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import { BUSINESS } from '../consts';

/*
 * The homepage links here via its "Accreditations" button. On the old site this
 * page had a nav entry and a footer and nothing else, so there is no copy to
 * carry over — this holds the homepage's own accreditations text so the button
 * does not lead to a dead end. Not in the nav until there are real credentials
 * to list.
 */
---

<Base
  title="Accreditations"
  description="Germ Solutions USA follows industry guidelines and the specific standards necessary to remain compliant."
  noindex
>
  <PageHero
    eyebrow="Accreditations"
    title="Our Customers Are Our Priority!"
    lead="Germ Solutions USA is deeply committed to all aspects related to the quality of indoor air. We follow industry guidelines and the specific standards necessary to remain compliant."
  />

  <Section>
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-lg leading-relaxed text-slate-600">
        Our credentials are being compiled for this page. In the meantime, we are happy to provide documentation on
        request — certifications, test data and compliance records for any system we install.
      </p>
      <div class="mt-9 flex flex-col justify-center gap-3 sm:flex-row">
        <a
          href="/contact"
          class="rounded-lg bg-accent-500 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-accent-600"
        >
          Request our credentials
        </a>
        <a
          href={`tel:${BUSINESS.phoneHref}`}
          class="rounded-lg border border-slate-300 px-7 py-3.5 font-semibold text-slate-700 transition-colors hover:border-brand-400 hover:text-brand-600"
        >
          Call {BUSINESS.phone}
        </a>
      </div>
    </div>
  </Section>
</Base>
